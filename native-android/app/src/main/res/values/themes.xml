<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base platform theme. Compose draws the real UI via WirewayTheme; this
         only needs to be a dark, edge-to-edge shell so there is no white flash
         before the first frame. -->
    <style name="Theme.Wireway" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/brand_background</item>
        <item name="android:statusBarColor">@color/brand_background</item>
        <item name="android:navigationBarColor">@color/brand_background</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
