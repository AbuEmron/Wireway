<?xml version="1.0" encoding="utf-8"?>
<!--
  Wireway mark — a blue→cyan gradient ring, a bold blue→purple "W", and a bright
  cyan lightning bolt slashing through it. Recreated as a clean vector from the
  brand mockup. 24x24 unit grid; scaled up for the launcher icon.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Ring (open where the bolt crosses top-right) -->
    <path
        android:fillType="evenOdd"
        android:pathData="M1.5,12 a10.5,10.5 0 1,0 21,0 a10.5,10.5 0 1,0 -21,0 Z M3.6,12 a8.4,8.4 0 1,0 16.8,0 a8.4,8.4 0 1,0 -16.8,0 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="20" android:startY="4"
                android:endX="4" android:endY="20">
                <item android:offset="0" android:color="#FF23DBFF" />
                <item android:offset="0.55" android:color="#FF3A78FF" />
                <item android:offset="1" android:color="#FF4B45E8" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Bold "W" (four thick strokes as filled quads) -->
    <path
        android:pathData="M3.477,9.148 L5.723,8.052 L9.723,16.252 L7.477,17.348 Z M9.6685,17.4488 L7.5315,16.1512 L10.9315,10.5512 L13.0685,11.8488 Z M10.9315,11.8488 L13.0685,10.5512 L16.4685,16.1512 L14.3315,17.4488 Z M16.5234,17.348 L14.2766,16.252 L18.2766,8.052 L20.5234,9.148 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="12" android:startY="8"
                android:endX="12" android:endY="17.5">
                <item android:offset="0" android:color="#FF2E6BFF" />
                <item android:offset="1" android:color="#FF6B3CEA" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Lightning bolt (bright cyan, drawn on top) -->
    <path
        android:pathData="M17.6,2.2 L11.5,12 L14.3,12 L12.3,21 L18.9,10 L15.3,10 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="18" android:startY="3"
                android:endX="12" android:endY="20">
                <item android:offset="0" android:color="#FF9CEEFF" />
                <item android:offset="1" android:color="#FFDBF7FF" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
