# ── Wireway Pro — Android upload-key signing ─────────────────────────────────
# Copy this file to:   android/keystore.properties
# (that real file is GITIGNORED and must NEVER be committed.)
#
# Fill in the values for the PWABuilder-generated UPLOAD keystore that you
# already use for the Play Store closed-testing track. Google Play App Signing
# is enabled, so this is your *upload* key — Google re-signs with the app key.
#
# Alternatively, set these same names as environment variables instead of using
# this file (build.gradle falls back to env vars):
#   WIREWAY_KEYSTORE_FILE, WIREWAY_KEYSTORE_PASSWORD, WIREWAY_KEY_ALIAS, WIREWAY_KEY_PASSWORD

# Absolute path (or path relative to the android/ folder) to your .keystore / .jks file:
WIREWAY_KEYSTORE_FILE=/absolute/path/to/wireway-upload.keystore

# Keystore (store) password:
WIREWAY_KEYSTORE_PASSWORD=CHANGE_ME

# Key alias inside the keystore (PWABuilder commonly uses "my-key-alias" — confirm yours):
WIREWAY_KEY_ALIAS=CHANGE_ME

# Key password (often the same as the keystore password for PWABuilder keys):
WIREWAY_KEY_PASSWORD=CHANGE_ME
